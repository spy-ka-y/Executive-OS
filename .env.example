# Copy this file to .env and fill in real values. Never commit .env.

# Supabase (client + SSR)
SUPABASE_PROJECT_ID=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Gemini (server-side only — never expose to the browser)
GEMINI_API_KEY=

# LLM cost controls (all optional; sensible defaults if unset)
# Preferred model (otherwise a free-tier-friendly fallback chain is used).
GEMINI_MODEL=
# Max live model calls per day per server instance before falling back to the
# built-in engine (protects free-tier quota / spend). Default 250.
LLM_DAILY_CALL_BUDGET=
# How long identical prompts are served from the in-memory cache, in ms. Default 3600000 (1h).
LLM_CACHE_TTL_MS=

# Aurora PostgreSQL — used ONLY by the LLM eval harness (npm run eval:agent)
# to read eval_golden_seed and write eval_runs. Standard libpq connection string.
DATABASE_URL=

# LLM eval harness knobs (optional)
# Minimum pass rate (0..1) below which `npm run eval:agent` exits non-zero.
EVAL_MIN_PASS_RATE=1.0
