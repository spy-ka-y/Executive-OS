# Environment variables / secrets — never commit these
.env
.env.*
!.env.example

# Python ML pipeline — keep the .onnx (app runtime needs it) + scripts; ignore
# the intermediate joblib and caches (regenerable via ml/train_risk_model.py).
__pycache__/
*.pyc
ml/*.joblib

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
.output
.vercel
.vinxi
.tanstack/**
.nitro
*.local

# Wrangler / Cloudflare
.wrangler/
.dev.vars

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
